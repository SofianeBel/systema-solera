# Solera Live is disabled by default for local development.
SOLERA_LIVE_ENABLED=false

# Set true to expose the opt-in multiplayer UI and server endpoints.
# Without ABLY_API_KEY, the app uses the local mock realtime adapter.
# For production multiplayer, set SOLERA_LIVE_ENABLED=true and ABLY_API_KEY.
SOLERA_LIVE_REALTIME_PROVIDER=mock
SOLERA_LIVE_DEFAULT_REGION=eu

# Server-only. Never prefix this with NEXT_PUBLIC_.
ABLY_API_KEY=
